API_KEY=默认使用通义千问,apikey通过百炼模型平台获取
COOKIES_STR=your_cookies_here
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-max
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=False

# 运行模式（True=无头模式，适合Docker；False=可交互输入）
HEADLESS=True

# 闲鱼接口配置（通常无需修改）
# GOOFISH_WS_URL=wss://wss-goofish.dingtalk.com/
# GOOFISH_APP_KEY=34839810
# GOOFISH_WS_APP_KEY=444e9908a51d1cb236a27862abc769c9
# GOOFISH_API_URL=https://h5api.m.goofish.com/h5/mtop.taobao.idlemessage.pc.login.token/1.0/

# 心跳与连接
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
MAX_RECONNECT_DELAY=300
MAX_RECONNECT_ATTEMPTS=0

# Token 刷新
TOKEN_REFRESH_INTERVAL=3600
TOKEN_RETRY_INTERVAL=300

# 消息处理
MESSAGE_EXPIRE_TIME=300000
MSG_CACHE_SIZE=1000
REPLY_COOLDOWN=1.0
MANUAL_MODE_TIMEOUT=3600
LOG_LEVEL=DEBUG

# LLM 参数
REACT_MAX_STEPS=4
RAG_TEMPERATURE=0.3
MAX_TOKENS=1500
LLM_TOP_P=0.8
LLM_TIMEOUT=30
RAG_STRICT=True

# RAG 知识库配置
DOCS_DIR=
RAG_ENABLED=True
RAG_TOP_K=5
RAG_THRESHOLD=0.5
RAG_BM25=True
RAG_BM25_WEIGHT=0.2
RAG_VECTOR_WEIGHT=0.8
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
CHROMA_DB_PATH=data/chroma_db
